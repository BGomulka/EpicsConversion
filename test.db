record(ai, "TEST:SYS:AI01") {
    field(DESC, "Test Analog Input 1")
    field(VAL, "0.0")
    field(SCAN, "1 second")
    field(EGU, "V")
}

record(ao, "TEST:SYS:AO01") {
    field(DESC, "Test Analog Output 1")
    field(VAL, "10.0")
    field(EGU, "A")
    # field(DRVH, "100")
}

record(bi, "TEST:SYS:BI01") {
    field(DESC, "Test Binary Input 1")
    field(VAL, "0")
    field(ZNAM, "Off")
    field(ONAM, "On")
}

record(bo, "TEST:SYS:BO01") {
    field(DESC, "Test Binary Output 1")
    field(VAL, "1")
    field(ZNAM, "Stop")
    field(ONAM, "Start")
}